# Copy this file to .env and fill in your key.

# Which backend to use: "google" (default) or "openrouter"
LLM_PROVIDER=google

# --- Google AI Studio ---
# Get a key from Google AI Studio: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyAAafNmEd2nu9P09c8IsM8zyZ6ragP6eB8

# Optional overrides
# gemini-flash-latest always points at Google's current GA Flash model.
MODEL=gemini-flash-latest

# --- OpenRouter (use if LLM_PROVIDER=openrouter) ---
# Get a key from https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

PORT=3000

# Botpress webchat (casual chatbot tab).
# Find these under your bot's Webchat > Share/Embed settings in Botpress Cloud.
# They are public client-side identifiers, not secret keys — safe to ship to
# the browser, which is why the server just hands them back via /api/config.
BOTPRESS_BOT_ID=your-botpress-bot-id
BOTPRESS_CLIENT_ID=your-botpress-client-id
